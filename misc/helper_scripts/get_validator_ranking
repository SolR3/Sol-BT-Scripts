#!/usr/bin/env python3

# Reference docs for calculating alpha price
# https://docs.taostats.io/docs/alpha-emission
# https://docs.taostats.io/docs/subnet-pools

# Standard imports
import argparse
import asyncio
from dataclasses import dataclass, field
from rich.text import Text
from rich.console import Console


